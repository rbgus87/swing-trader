# 모의/실전 구분 (True=모의투자, False=실거래)
IS_PAPER_TRADING=True

# 키움 OpenAPI+ 계좌번호 (필수)
KIWOOM_ACCOUNT=your_account_number

# 텔레그램 봇 토큰 (필수 - Live 모드)
TELEGRAM_BOT_TOKEN=your_bot_token

# 텔레그램 채팅 ID (필수 - Live 모드)
TELEGRAM_CHAT_ID=your_chat_id

# 키움 REST API 앱키 (필수)
KIWOOM_APPKEY=your_appkey

# 키움 REST API 시크릿키 (필수)
KIWOOM_SECRETKEY=your_secretkey

# 설정 파일 경로 (선택, 기본: ./config.yaml)
CONFIG_PATH=./config.yaml

# 로그 레벨 (선택, 기본: INFO)
LOG_LEVEL=INFO

# KRX Open API 인증키 (선택 — 미설정 시 pykrx 폴백)
# 발급: https://openapi.krx.co.kr/ → 마이페이지 → API 인증키 신청
KRX_API_KEY=your_krx_api_key

# DART Open API 인증키 (선택 — 재무제표 조회용)
# 발급: https://opendart.fss.or.kr/ → 인증키 신청
DART_API_KEY=your_dart_api_key
